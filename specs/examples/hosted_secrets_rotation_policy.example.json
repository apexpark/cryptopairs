{
  "version": 1,
  "provider": "vault_or_kms",
  "rotation_default_hours": 720,
  "secrets": [
    {
      "name": "Kraken API Key",
      "value_env": "KRAKEN_FUTURES_API_KEY",
      "value_file_env": "KRAKEN_FUTURES_API_KEY_FILE",
      "reference_env": "KRAKEN_FUTURES_API_KEY_REF",
      "max_age_hours": 720
    },
    {
      "name": "Kraken API Secret",
      "value_env": "KRAKEN_FUTURES_API_SECRET",
      "value_file_env": "KRAKEN_FUTURES_API_SECRET_FILE",
      "reference_env": "KRAKEN_FUTURES_API_SECRET_REF",
      "max_age_hours": 720
    }
  ]
}
