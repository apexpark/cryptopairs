{
  "$id": "https://cryptopairs/specs/contracts/data_query_response.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DataQueryResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "instrument",
    "timeframe",
    "start_ts",
    "end_ts",
    "candles",
    "integrity"
  ],
  "properties": {
    "instrument": {
      "type": "string",
      "minLength": 1
    },
    "timeframe": {
      "type": "string",
      "enum": ["1m", "15m", "1h"]
    },
    "start_ts": {
      "type": "string",
      "format": "date-time"
    },
    "end_ts": {
      "type": "string",
      "format": "date-time"
    },
    "candles": {
      "type": "array",
      "items": {
        "$ref": "candle.schema.json"
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "coverage_pct",
        "missing_ranges",
        "last_verified_at",
        "warnings"
      ],
      "properties": {
        "status": {
          "$ref": "integrity_status.schema.json"
        },
        "coverage_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "missing_ranges": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["start_ts", "end_ts", "reason"],
            "properties": {
              "start_ts": {
                "type": "string",
                "format": "date-time"
              },
              "end_ts": {
                "type": "string",
                "format": "date-time"
              },
              "reason": {
                "type": "string"
              }
            }
          }
        },
        "last_verified_at": {
          "type": "string",
          "format": "date-time"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "version": "0.1.0"
}
