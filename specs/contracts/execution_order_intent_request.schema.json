{
  "$id": "https://cryptopairs/specs/contracts/execution_order_intent_request.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExecutionOrderIntentRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "idempotency_key",
    "instrument",
    "timeframe",
    "side",
    "qty"
  ],
  "properties": {
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "instrument": {
      "type": "string",
      "minLength": 1
    },
    "timeframe": {
      "type": "string",
      "enum": ["1m", "15m", "1h"]
    },
    "side": {
      "type": "string",
      "enum": ["BUY", "SELL"]
    },
    "qty": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "min_coverage_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    }
  },
  "version": "0.1.0"
}
