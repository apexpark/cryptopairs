{
  "$id": "https://cryptopairs/specs/contracts/execution_order_intent_request.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExecutionOrderIntentRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "idempotency_key",
    "exchange",
    "account_id",
    "instrument",
    "timeframe",
    "action",
    "side",
    "qty",
    "operator_confirmed"
  ],
  "properties": {
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "exchange": {
      "type": "string",
      "minLength": 1
    },
    "account_id": {
      "type": "string",
      "minLength": 1
    },
    "pair_id": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "instrument": {
      "type": "string",
      "minLength": 1
    },
    "timeframe": {
      "type": "string",
      "enum": ["1m", "15m", "1h"]
    },
    "action": {
      "type": "string",
      "enum": ["ENTRY", "EXIT", "EMERGENCY_STOP_CLOSE"]
    },
    "spread_direction": {
      "type": ["string", "null"],
      "enum": ["LONG_SPREAD", "SHORT_SPREAD", null]
    },
    "spread_z": {
      "type": ["number", "null"]
    },
    "side": {
      "type": "string",
      "enum": ["BUY", "SELL"]
    },
    "qty": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "operator_confirmed": {
      "type": "boolean"
    },
    "operator_id": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "min_coverage_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "action": { "enum": ["ENTRY", "EXIT"] }
        }
      },
      "then": {
        "required": ["operator_id"],
        "properties": {
          "operator_confirmed": { "const": true }
        }
      }
    }
  ],
  "version": "0.1.0"
}
