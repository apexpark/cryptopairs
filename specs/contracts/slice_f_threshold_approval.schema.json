{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cryptopairs.local/specs/contracts/slice_f_threshold_approval.schema.json",
  "title": "Slice F CPU and hot endpoint threshold approval",
  "description": "Operator-captured approval artifact for Slice F CPU and hot endpoint latency thresholds. This contract records approval evidence only; it does not authorize runner enablement, scheduler enablement, live ENTRY/EXIT, automatic PROMOTE, automatic REVERT, or repair-provenance graduation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "approved_before_canary",
    "approval",
    "cpu",
    "hot_endpoints"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0.0"] },
    "approved_before_canary": { "type": "boolean", "const": true },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reference",
        "approved_at",
        "approved_by",
        "scope",
        "abort_rule",
        "host_evidence_owner"
      ],
      "properties": {
        "reference": { "type": "string", "minLength": 1 },
        "approved_at": { "type": "string", "format": "date-time" },
        "approved_by": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 },
        "abort_rule": { "type": "string", "minLength": 1 },
        "host_evidence_owner": { "type": "string", "enum": ["operator"] }
      }
    },
    "cpu": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_source",
        "query",
        "aggregation_window_seconds",
        "baseline_window_seconds",
        "threshold_type",
        "threshold_value"
      ],
      "properties": {
        "metric_source": { "type": "string", "minLength": 1 },
        "query": { "type": "string", "minLength": 1 },
        "aggregation_window_seconds": { "type": "integer", "minimum": 1 },
        "baseline_window_seconds": { "type": "integer", "minimum": 1 },
        "threshold_type": { "type": "string", "enum": ["ABSOLUTE", "RELATIVE_INCREASE"] },
        "threshold_value": { "type": "number", "minimum": 0 }
      }
    },
    "hot_endpoints": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/hot_endpoint_threshold" }
    }
  },
  "$defs": {
    "hot_endpoint_threshold": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "path",
        "metric_source",
        "query",
        "statistic",
        "baseline_window_seconds",
        "threshold_type",
        "threshold_value"
      ],
      "properties": {
        "method": { "type": "string", "enum": ["GET", "POST"] },
        "path": { "type": "string", "minLength": 1 },
        "metric_source": { "type": "string", "minLength": 1 },
        "query": { "type": "string", "minLength": 1 },
        "statistic": { "type": "string", "enum": ["p95", "p99", "max"] },
        "baseline_window_seconds": { "type": "integer", "minimum": 1 },
        "threshold_type": { "type": "string", "enum": ["ABSOLUTE", "RELATIVE_INCREASE"] },
        "threshold_value": { "type": "number", "minimum": 0 }
      }
    }
  }
}
