{
  "$id": "https://cryptopairs/specs/contracts/strategy_pairs_cues_response.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StrategyPairsCuesResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["timeframe", "generated_at", "cues", "candidate_set", "portfolio_plan", "skipped"],
  "properties": {
    "timeframe": {
      "type": "string",
      "enum": ["1m", "15m", "1h"]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "cues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cue", "variants", "half_life_bars", "hedge_ratio", "hedge_ratio_stability"],
        "properties": {
          "cue": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "pair_id",
              "left_instrument",
              "right_instrument",
              "timeframe",
              "regime",
              "selected_variant",
              "direction_hint",
              "spread_z",
              "opportunity_score",
              "confidence_band",
              "entry_band",
              "exit_band",
              "stop_band",
              "expected_hold_bars",
              "cost_estimate_bps",
              "actionable",
              "rationale_codes",
              "cost_gate",
              "portfolio_hint",
              "shadow_ml",
              "evaluated_at"
            ],
            "properties": {
              "pair_id": { "type": "string" },
              "left_instrument": { "type": "string" },
              "right_instrument": { "type": "string" },
              "timeframe": { "type": "string", "enum": ["1m", "15m", "1h"] },
              "regime": { "type": "string", "enum": ["CALM", "TRENDING", "SHOCK"] },
              "selected_variant": {
                "type": "string",
                "enum": ["COINTEGRATION_Z", "ROBUST_Z", "VOL_NORMALIZED", "FUNDING_ADJUSTED"]
              },
              "direction_hint": { "type": "string", "enum": ["LONG_SPREAD", "SHORT_SPREAD", "NONE"] },
              "spread_z": { "type": "number" },
              "opportunity_score": { "type": "number" },
              "confidence_band": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
              "entry_band": { "type": "number" },
              "exit_band": { "type": "number" },
              "stop_band": { "type": "number" },
              "expected_hold_bars": { "type": "integer", "minimum": 1 },
              "cost_estimate_bps": { "type": "number" },
              "actionable": { "type": "boolean" },
              "rationale_codes": {
                "type": "array",
                "items": { "type": "string" }
              },
              "cost_gate": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "status",
                  "expected_edge_bps",
                  "fee_bps",
                  "funding_model",
                  "funding_events",
                  "funding_bps_per_event",
                  "funding_bps",
                  "slippage_bps",
                  "net_edge_bps",
                  "pass",
                  "rationale_codes"
                ],
                "properties": {
                  "status": { "type": "string", "enum": ["AVAILABLE", "UNAVAILABLE"] },
                  "expected_edge_bps": { "type": "number" },
                  "fee_bps": { "type": "number", "minimum": 0 },
                  "funding_model": { "type": "string", "enum": ["STATIC", "DYNAMIC"] },
                  "funding_events": { "type": "integer", "minimum": 0 },
                  "funding_bps_per_event": { "type": "number" },
                  "funding_bps": { "type": "number" },
                  "slippage_bps": { "type": "number", "minimum": 0 },
                  "net_edge_bps": { "type": "number" },
                  "pass": { "type": "boolean" },
                  "rationale_codes": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              },
              "portfolio_hint": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "status",
                  "target_weight",
                  "risk_contribution",
                  "cap_applied",
                  "rationale_codes"
                ],
                "properties": {
                  "status": { "type": "string", "enum": ["AVAILABLE", "UNAVAILABLE"] },
                  "target_weight": { "type": "number" },
                  "risk_contribution": { "type": "number", "minimum": 0, "maximum": 1 },
                  "cap_applied": { "type": "boolean" },
                  "rationale_codes": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              },
              "shadow_ml": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "status",
                  "model_name",
                  "training_rows",
                  "positive_rate",
                  "precision",
                  "brier_score",
                  "recommended_variant",
                  "recommended_probability",
                  "agrees_with_selected",
                  "rationale_codes"
                ],
                "properties": {
                  "status": { "type": "string", "enum": ["AVAILABLE", "UNAVAILABLE"] },
                  "model_name": { "type": "string" },
                  "training_rows": { "type": "integer", "minimum": 0 },
                  "positive_rate": { "type": "number", "minimum": 0, "maximum": 1 },
                  "precision": { "type": "number", "minimum": 0, "maximum": 1 },
                  "brier_score": { "type": "number", "minimum": 0, "maximum": 1 },
                  "recommended_variant": {
                    "type": "string",
                    "enum": ["COINTEGRATION_Z", "ROBUST_Z", "VOL_NORMALIZED", "FUNDING_ADJUSTED", "NONE"]
                  },
                  "recommended_probability": { "type": "number", "minimum": 0, "maximum": 1 },
                  "agrees_with_selected": { "type": "boolean" },
                  "rationale_codes": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              },
              "evaluated_at": { "type": "string", "format": "date-time" }
            }
          },
          "variants": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "variant",
                "score_last",
                "sample_count",
                "win_rate",
                "edge_bps",
                "reliability",
                "regime_fit",
                "opportunity_score",
                "rationale_codes"
              ],
              "properties": {
                "variant": {
                  "type": "string",
                  "enum": ["COINTEGRATION_Z", "ROBUST_Z", "VOL_NORMALIZED", "FUNDING_ADJUSTED"]
                },
                "score_last": { "type": "number" },
                "sample_count": { "type": "integer", "minimum": 0 },
                "win_rate": { "type": "number", "minimum": 0, "maximum": 1 },
                "edge_bps": { "type": "number" },
                "reliability": { "type": "number", "minimum": 0, "maximum": 1 },
                "regime_fit": { "type": "number", "minimum": 0 },
                "opportunity_score": { "type": "number" },
                "shadow_success_probability": {
                  "type": ["number", "null"],
                  "minimum": 0,
                  "maximum": 1
                },
                "shadow_rank_score": {
                  "type": ["number", "null"]
                },
                "rationale_codes": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          },
          "half_life_bars": { "type": "number", "minimum": 0 },
          "hedge_ratio": { "type": "number" },
          "hedge_ratio_stability": { "type": "number", "minimum": 0 }
        }
      }
    },
    "candidate_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_pairs",
        "evaluated_pairs",
        "actionable_pairs",
        "cost_gate_pass_pairs",
        "shadow_disagreement_pairs"
      ],
      "properties": {
        "total_pairs": { "type": "integer", "minimum": 0 },
        "evaluated_pairs": { "type": "integer", "minimum": 0 },
        "actionable_pairs": { "type": "integer", "minimum": 0 },
        "cost_gate_pass_pairs": { "type": "integer", "minimum": 0 },
        "shadow_disagreement_pairs": { "type": "integer", "minimum": 0 }
      }
    },
    "portfolio_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "weights", "constraints", "rationale_codes"],
      "properties": {
        "status": { "type": "string", "enum": ["AVAILABLE", "UNAVAILABLE"] },
        "weights": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["pair_id", "target_weight", "risk_contribution", "cap_applied"],
            "properties": {
              "pair_id": { "type": "string" },
              "target_weight": { "type": "number" },
              "risk_contribution": { "type": "number", "minimum": 0, "maximum": 1 },
              "cap_applied": { "type": "boolean" }
            }
          }
        },
        "constraints": {
          "type": "object",
          "additionalProperties": false,
          "required": ["dollar_neutral", "gross_cap", "per_pair_cap"],
          "properties": {
            "dollar_neutral": { "type": "boolean" },
            "gross_cap": { "type": "number", "minimum": 0 },
            "per_pair_cap": { "type": "number", "minimum": 0 }
          }
        },
        "rationale_codes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "skipped": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pair_id", "reason"],
        "properties": {
          "pair_id": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    }
  },
  "version": "0.1.0"
}
