{
  "$id": "https://cryptopairs/specs/contracts/account_observability_summary_response.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AccountObservabilitySummaryResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated_at",
    "exchange",
    "account_id",
    "window_minutes",
    "thresholds",
    "metrics",
    "alerts"
  ],
  "properties": {
    "generated_at": { "type": "string", "format": "date-time" },
    "exchange": { "type": "string" },
    "account_id": { "type": "string" },
    "window_minutes": { "type": "integer", "minimum": 1 },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_snapshot_age_seconds_p1",
        "reconcile_non_ok_count_p2"
      ],
      "properties": {
        "max_snapshot_age_seconds_p1": { "type": "integer", "minimum": 0 },
        "reconcile_non_ok_count_p2": { "type": "integer", "minimum": 0 }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "latest_snapshot_age_seconds",
        "latest_reconcile_status",
        "reconcile_events_total",
        "reconcile_non_ok_count",
        "stale_snapshot_count",
        "drift_exceeded_count"
      ],
      "properties": {
        "latest_snapshot_age_seconds": { "type": "integer", "minimum": 0 },
        "latest_reconcile_status": { "type": "string" },
        "reconcile_events_total": { "type": "integer", "minimum": 0 },
        "reconcile_non_ok_count": { "type": "integer", "minimum": 0 },
        "stale_snapshot_count": { "type": "integer", "minimum": 0 },
        "drift_exceeded_count": { "type": "integer", "minimum": 0 }
      }
    },
    "alerts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity", "triggered", "message"],
        "properties": {
          "code": { "type": "string" },
          "severity": { "type": "string", "enum": ["P1", "P2", "P3"] },
          "triggered": { "type": "boolean" },
          "message": { "type": "string" }
        }
      }
    }
  },
  "version": "0.1.0"
}
