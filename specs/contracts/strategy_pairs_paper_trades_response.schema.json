{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cryptopairs/specs/contracts/strategy_pairs_paper_trades_response.schema.json",
  "title": "Strategy Pairs Paper Trades Response",
  "type": "object",
  "required": [
    "timeframe",
    "generated_at",
    "hours",
    "pair_id",
    "exit_mode",
    "model_bars",
    "rows"
  ],
  "properties": {
    "timeframe": { "type": "string", "enum": ["1m", "15m", "1h"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "hours": { "type": "integer", "minimum": 1 },
    "pair_id": { "type": ["string", "null"] },
    "exit_mode": { "type": "string", "enum": ["mean_revert", "opposite_extreme"] },
    "model_bars": { "type": "integer", "minimum": 1 },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pair_id",
          "timeframe",
          "exit_mode",
          "left_instrument",
          "right_instrument",
          "selected_variant",
          "entry_ts",
          "exit_ts",
          "bars_held",
          "direction",
          "exit_kind",
          "entry_z",
          "exit_z",
          "entry_index",
          "exit_index",
          "left_entry",
          "left_exit",
          "right_entry",
          "right_exit",
          "left_leg_bps",
          "right_leg_bps",
          "gross_bps",
          "round_trip_cost_bps",
          "net_bps",
          "equity_pre_entry",
          "equity_exit",
          "equity_trade_bps",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "pair_id": { "type": "string" },
          "timeframe": { "type": "string", "enum": ["1m", "15m", "1h"] },
          "exit_mode": { "type": "string", "enum": ["mean_revert", "opposite_extreme"] },
          "left_instrument": { "type": "string" },
          "right_instrument": { "type": "string" },
          "selected_variant": { "type": "string" },
          "entry_ts": { "type": "string", "format": "date-time" },
          "exit_ts": { "type": "string", "format": "date-time" },
          "bars_held": { "type": "integer", "minimum": 1 },
          "direction": { "type": "string", "enum": ["LONG_SPREAD", "SHORT_SPREAD"] },
          "exit_kind": { "type": "string", "enum": ["exit", "stop"] },
          "entry_z": { "type": "number" },
          "exit_z": { "type": "number" },
          "entry_index": { "type": "integer", "minimum": 0 },
          "exit_index": { "type": "integer", "minimum": 0 },
          "left_entry": { "type": "number" },
          "left_exit": { "type": "number" },
          "right_entry": { "type": "number" },
          "right_exit": { "type": "number" },
          "left_leg_bps": { "type": "number" },
          "right_leg_bps": { "type": "number" },
          "gross_bps": { "type": "number" },
          "round_trip_cost_bps": { "type": "number", "minimum": 0 },
          "net_bps": { "type": "number" },
          "equity_pre_entry": { "type": "number", "exclusiveMinimum": 0 },
          "equity_exit": { "type": "number", "exclusiveMinimum": 0 },
          "equity_trade_bps": { "type": "number" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
