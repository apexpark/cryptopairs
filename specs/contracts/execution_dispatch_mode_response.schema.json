{
  "$id": "https://cryptopairs/specs/contracts/execution_dispatch_mode_response.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExecutionDispatchModeResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mode",
    "requires_live_arm",
    "sizing_tolerance_notional_drift_pct",
    "sizing_tolerance_hedge_ratio_drift_pct"
  ],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["FAIL_CLOSED", "SIMULATE_ACK", "LIVE_KRAKEN"]
    },
    "requires_live_arm": {
      "type": "boolean"
    },
    "sizing_tolerance_notional_drift_pct": {
      "type": "number",
      "minimum": 0
    },
    "sizing_tolerance_hedge_ratio_drift_pct": {
      "type": "number",
      "minimum": 0
    }
  },
  "version": "0.1.0"
}
