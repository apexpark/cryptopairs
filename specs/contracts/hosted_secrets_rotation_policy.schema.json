{
  "$id": "https://cryptopairs/specs/contracts/hosted_secrets_rotation_policy.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HostedSecretsRotationPolicy",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "provider", "rotation_default_hours", "secrets"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "provider": { "type": "string" },
    "rotation_default_hours": { "type": "integer", "minimum": 1 },
    "secrets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "value_env",
          "value_file_env",
          "reference_env",
          "max_age_hours"
        ],
        "properties": {
          "name": { "type": "string" },
          "value_env": { "type": "string" },
          "value_file_env": { "type": "string" },
          "reference_env": { "type": "string" },
          "max_age_hours": { "type": "integer", "minimum": 1 }
        }
      }
    }
  },
  "version": "0.1.0"
}
