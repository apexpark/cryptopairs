{
  "$id": "https://cryptopairs/specs/contracts/candle.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Candle",
  "type": "object",
  "additionalProperties": false,
  "required": ["ts", "open", "high", "low", "close", "volume"],
  "properties": {
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "open": {
      "type": "number"
    },
    "high": {
      "type": "number"
    },
    "low": {
      "type": "number"
    },
    "close": {
      "type": "number"
    },
    "volume": {
      "type": "number"
    }
  },
  "version": "0.1.0"
}
