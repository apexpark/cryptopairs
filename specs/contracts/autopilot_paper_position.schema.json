{
  "$id": "https://cryptopairs/specs/contracts/autopilot_paper_position.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AutopilotPaperPosition",
  "description": "Append-only paper-only autopilot position lifecycle record. This artifact is simulated paper state, not a live order, live position, or execution-service intent.",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "OPEN"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "entry_observe_key": {
            "type": "string",
            "minLength": 1
          },
          "entry_observed_at": {
            "type": "string",
            "format": "date-time"
          },
          "exit_eligible_at": {
            "type": "string",
            "format": "date-time"
          },
          "hold_window_bars": {
            "type": "integer",
            "minimum": 1,
            "maximum": 240
          },
          "exit_observed_at": {
            "type": "null"
          },
          "exit_reason": {
            "type": "null"
          },
          "exit_source_type": {
            "type": "null"
          },
          "realized_net_bps": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "CLOSED"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "entry_observe_key": {
            "type": "string",
            "minLength": 1
          },
          "exit_observed_at": {
            "type": "string",
            "format": "date-time"
          },
          "exit_reason": {
            "type": "string",
            "const": "HOLD_WINDOW_MARK"
          },
          "exit_source_type": {
            "type": "string",
            "enum": [
              "paper_trade_outcome",
              "mark_adapter"
            ]
          },
          "realized_net_bps": {
            "type": "number"
          }
        }
      }
    }
  ],
  "required": [
    "schema_version",
    "mode",
    "paper_position_id",
    "pair_id",
    "timeframe",
    "selected_variant",
    "direction",
    "status",
    "entry_observed_at",
    "entry_score_z",
    "entry_net_edge_bps",
    "source_generated_at",
    "entry_observe_key",
    "hold_window_bars",
    "exit_eligible_at",
    "exit_observed_at",
    "exit_reason",
    "exit_source_type",
    "realized_net_bps"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "mode": {
      "type": "string",
      "const": "paper_only"
    },
    "paper_position_id": {
      "type": "string",
      "minLength": 1
    },
    "pair_id": {
      "type": "string",
      "minLength": 1
    },
    "timeframe": {
      "type": "string",
      "const": "1m"
    },
    "selected_variant": {
      "type": "string",
      "minLength": 1
    },
    "direction": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "OPEN",
        "CLOSED"
      ]
    },
    "entry_observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "entry_score_z": {
      "type": [
        "number",
        "null"
      ]
    },
    "entry_net_edge_bps": {
      "type": [
        "number",
        "null"
      ]
    },
    "source_generated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "entry_observe_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "hold_window_bars": {
      "type": "integer",
      "minimum": 1,
      "maximum": 240
    },
    "exit_eligible_at": {
      "type": "string",
      "format": "date-time"
    },
    "exit_observed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "exit_reason": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "HOLD_WINDOW_MARK",
        null
      ]
    },
    "exit_source_type": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "paper_trade_outcome",
        "mark_adapter",
        null
      ]
    },
    "realized_net_bps": {
      "type": [
        "number",
        "null"
      ]
    }
  }
}
