{
  "$id": "https://cryptopairs/specs/contracts/strategy_pairs_cost_gate_response.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StrategyPairsCostGateResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["timeframe", "generated_at", "gates", "skipped"],
  "properties": {
    "timeframe": {
      "type": "string",
      "enum": ["1m", "15m", "1h"]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pair_id",
          "left_instrument",
          "right_instrument",
          "timeframe",
          "expected_edge_bps",
          "fee_bps",
          "funding_model",
          "funding_events",
          "funding_bps_per_event",
          "funding_bps",
          "slippage_bps",
          "net_edge_bps",
          "pass",
          "setup_pass",
          "trade_ready",
          "trade_blocked_by",
          "rationale_codes"
        ],
        "properties": {
          "pair_id": { "type": "string" },
          "left_instrument": { "type": "string" },
          "right_instrument": { "type": "string" },
          "timeframe": { "type": "string", "enum": ["1m", "15m", "1h"] },
          "expected_edge_bps": { "type": "number" },
          "fee_bps": { "type": "number", "minimum": 0 },
          "funding_model": { "type": "string", "enum": ["STATIC", "DYNAMIC"] },
          "funding_events": { "type": "integer", "minimum": 0 },
          "funding_bps_per_event": { "type": "number" },
          "funding_bps": { "type": "number" },
          "slippage_bps": { "type": "number", "minimum": 0 },
          "net_edge_bps": { "type": "number" },
          "pass": { "type": "boolean" },
          "setup_pass": { "type": "boolean" },
          "trade_ready": { "type": "boolean" },
          "trade_blocked_by": {
            "type": "string",
            "enum": ["NONE", "SETUP", "COST", "MULTIPLE", "UNAVAILABLE"]
          },
          "rationale_codes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "skipped": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pair_id", "reason"],
        "properties": {
          "pair_id": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    }
  },
  "version": "0.1.0"
}
