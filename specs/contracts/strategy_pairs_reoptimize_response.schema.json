{
  "$id": "https://cryptopairs/specs/contracts/strategy_pairs_reoptimize_response.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StrategyPairsReoptimizeResponse",
  "type": "object",
  "additionalProperties": false,
  "$comment": "initialize_decisions and unchanged_decisions are kept optional in required for backward compatibility with pre-0.2.0 clients, but strategy-service always populates them.",
  "required": [
    "generated_at",
    "timeframes",
    "pairs_processed",
    "cues_generated",
    "performance_rows_written",
    "selected_rows_written",
    "drift_rows_written",
    "champion_promotions",
    "champion_locks",
    "shadow_model_runs_written",
    "shadow_model_available",
    "shadow_model_unavailable",
    "cost_gate_pass",
    "cost_gate_fail",
    "portfolio_advice_available",
    "portfolio_advice_unavailable",
    "errors"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "timeframes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["1m", "15m", "1h"]
      }
    },
    "pairs_processed": {
      "type": "integer",
      "minimum": 0
    },
    "cues_generated": {
      "type": "integer",
      "minimum": 0
    },
    "performance_rows_written": {
      "type": "integer",
      "minimum": 0
    },
    "selected_rows_written": {
      "type": "integer",
      "minimum": 0
    },
    "drift_rows_written": {
      "type": "integer",
      "minimum": 0
    },
    "initialize_decisions": {
      "description": "Always populated by current servers; kept optional in required for backward compatibility with pre-0.2.0 clients.",
      "type": "integer",
      "minimum": 0
    },
    "unchanged_decisions": {
      "description": "Always populated by current servers; kept optional in required for backward compatibility with pre-0.2.0 clients.",
      "type": "integer",
      "minimum": 0
    },
    "champion_promotions": {
      "type": "integer",
      "minimum": 0
    },
    "champion_locks": {
      "type": "integer",
      "minimum": 0
    },
    "shadow_model_runs_written": {
      "type": "integer",
      "minimum": 0
    },
    "shadow_model_available": {
      "type": "integer",
      "minimum": 0
    },
    "shadow_model_unavailable": {
      "type": "integer",
      "minimum": 0
    },
    "cost_gate_pass": {
      "type": "integer",
      "minimum": 0
    },
    "cost_gate_fail": {
      "type": "integer",
      "minimum": 0
    },
    "portfolio_advice_available": {
      "type": "integer",
      "minimum": 0
    },
    "portfolio_advice_unavailable": {
      "type": "integer",
      "minimum": 0
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pair_id", "timeframe", "error"],
        "properties": {
          "pair_id": { "type": "string" },
          "timeframe": { "type": "string", "enum": ["1m", "15m", "1h"] },
          "error": { "type": "string" }
        }
      }
    }
  },
  "version": "0.2.0"
}
