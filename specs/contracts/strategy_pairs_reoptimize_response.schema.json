{
  "$id": "https://cryptopairs/specs/contracts/strategy_pairs_reoptimize_response.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StrategyPairsReoptimizeResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated_at",
    "status",
    "timeframes",
    "pairs_processed",
    "cues_generated",
    "performance_rows_written",
    "selected_rows_written",
    "drift_rows_written",
    "champion_promotions",
    "champion_locks",
    "shadow_model_runs_written",
    "shadow_model_available",
    "shadow_model_unavailable",
    "cost_gate_pass",
    "cost_gate_fail",
    "portfolio_advice_available",
    "portfolio_advice_unavailable",
    "critical_error_count",
    "non_critical_error_count",
    "timeframe_statuses",
    "flatline_summary",
    "errors"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["OK", "DEGRADED", "FAILED"]
    },
    "timeframes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["1m", "15m", "1h"]
      }
    },
    "pairs_processed": {
      "type": "integer",
      "minimum": 0
    },
    "cues_generated": {
      "type": "integer",
      "minimum": 0
    },
    "performance_rows_written": {
      "type": "integer",
      "minimum": 0
    },
    "selected_rows_written": {
      "type": "integer",
      "minimum": 0
    },
    "drift_rows_written": {
      "type": "integer",
      "minimum": 0
    },
    "champion_promotions": {
      "type": "integer",
      "minimum": 0
    },
    "champion_locks": {
      "type": "integer",
      "minimum": 0
    },
    "shadow_model_runs_written": {
      "type": "integer",
      "minimum": 0
    },
    "shadow_model_available": {
      "type": "integer",
      "minimum": 0
    },
    "shadow_model_unavailable": {
      "type": "integer",
      "minimum": 0
    },
    "cost_gate_pass": {
      "type": "integer",
      "minimum": 0
    },
    "cost_gate_fail": {
      "type": "integer",
      "minimum": 0
    },
    "portfolio_advice_available": {
      "type": "integer",
      "minimum": 0
    },
    "portfolio_advice_unavailable": {
      "type": "integer",
      "minimum": 0
    },
    "critical_error_count": {
      "type": "integer",
      "minimum": 0
    },
    "non_critical_error_count": {
      "type": "integer",
      "minimum": 0
    },
    "timeframe_statuses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "timeframe",
          "status",
          "pairs_evaluated",
          "critical_error_count",
          "non_critical_error_count",
          "flatline_summary"
        ],
        "properties": {
          "timeframe": { "type": "string", "enum": ["1m", "15m", "1h"] },
          "status": { "type": "string", "enum": ["OK", "DEGRADED", "FAILED"] },
          "pairs_evaluated": { "type": "integer", "minimum": 0 },
          "critical_error_count": { "type": "integer", "minimum": 0 },
          "non_critical_error_count": { "type": "integer", "minimum": 0 },
          "flatline_summary": {
            "type": "object",
            "additionalProperties": false,
            "required": ["healthy_pairs", "warn_pairs", "flatline_pairs"],
            "properties": {
              "healthy_pairs": { "type": "integer", "minimum": 0 },
              "warn_pairs": { "type": "integer", "minimum": 0 },
              "flatline_pairs": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "flatline_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["healthy_pairs", "warn_pairs", "flatline_pairs"],
      "properties": {
        "healthy_pairs": { "type": "integer", "minimum": 0 },
        "warn_pairs": { "type": "integer", "minimum": 0 },
        "flatline_pairs": { "type": "integer", "minimum": 0 }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pair_id", "timeframe", "code", "severity", "error"],
        "properties": {
          "pair_id": { "type": "string" },
          "timeframe": { "type": "string", "enum": ["1m", "15m", "1h"] },
          "code": { "type": "string" },
          "severity": { "type": "string", "enum": ["CRITICAL", "NON_CRITICAL"] },
          "error": { "type": "string" }
        }
      }
    }
  },
  "version": "0.1.0"
}
