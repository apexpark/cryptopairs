# Live Mode (operator preset)
# Friendly mode name: Trading Mode = live_kraken

POSTGRES_URL=postgres://cryptopairs:cryptopairs@127.0.0.1:5432/cryptopairs
ACCOUNT_SERVICE_URL=http://127.0.0.1:8081

# Trading Mode (EXECUTION_DISPATCH_MODE)
EXECUTION_DISPATCH_MODE=live_kraken

# Kraken credentials (required)
KRAKEN_FUTURES_API_KEY=REPLACE_ME
KRAKEN_FUTURES_API_SECRET=REPLACE_ME_BASE64
KRAKEN_FUTURES_API_BASE_URL=https://futures.kraken.com
KRAKEN_FUTURES_SENDORDER_PATH=/derivatives/api/v3/sendorder
KRAKEN_FUTURES_OPENORDERS_PATH=/derivatives/api/v3/openorders
KRAKEN_FUTURES_ORDER_STATUS_PATH=/derivatives/api/v3/orders/status

# Open Orders Poller Enabled (EXECUTION_OPENORDERS_POLLER_ENABLED)
EXECUTION_OPENORDERS_POLLER_ENABLED=true
EXECUTION_OPENORDERS_POLL_SECONDS=5
EXECUTION_OPENORDERS_POLL_BATCH_LIMIT=200

# Order Status Lookup Enabled (EXECUTION_ORDER_STATUS_LOOKUP_ENABLED)
# Enable after verifying query key on your account (default candidate: orderId)
EXECUTION_ORDER_STATUS_LOOKUP_ENABLED=true
KRAKEN_FUTURES_ORDER_STATUS_QUERY_KEY=orderId

# Ack timeout safety controls
EXECUTION_ACK_WATCHDOG_POLL_SECONDS=15
EXECUTION_ACK_EXPIRE_AFTER_SECONDS=90
EXECUTION_ACK_WATCHDOG_BATCH_LIMIT=200

# Reconcile On Terminal State (EXECUTION_TRIGGER_RECONCILE_ON_TERMINAL)
EXECUTION_TRIGGER_RECONCILE_ON_TERMINAL=true

# Risk caps (ENTRY actions)
EXECUTION_RISK_PER_PAIR_MAX_QTY=12
EXECUTION_RISK_GROSS_MAX_QTY=40
EXECUTION_RISK_MAX_LEVERAGE=3.0
EXECUTION_RISK_DAILY_LOSS_LIMIT_USD=500
EXECUTION_RISK_ENTRY_COOLDOWN_SECONDS=30
EXECUTION_RISK_MAX_SNAPSHOT_AGE_SECONDS=120

# Observability alert thresholds
EXECUTION_ALERT_RISK_BLOCK_RATIO_P2=0.25
EXECUTION_ALERT_DISPATCH_REJECT_RATIO_P2=0.15
EXECUTION_ALERT_STALE_ACK_COUNT_P1=1
EXECUTION_ALERT_RECONCILE_BLOCK_COUNT_P1=1
ACCOUNT_ALERT_MAX_SNAPSHOT_AGE_SECONDS_P1=120
ACCOUNT_ALERT_RECONCILE_NON_OK_COUNT_P2=1
